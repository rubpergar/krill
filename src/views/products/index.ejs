<h2 class="text-2xl font-bold mb-6">Productos</h2>

<% if (success) { %>
  <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
    <% if (success === 'created') { %>Producto creado exitosamente.<% } %>
    <% if (success === 'updated') { %>Producto actualizado exitosamente.<% } %>
    <% if (success === 'toggled') { %>Estado de producto actualizado.<% } %>
  </div>
<% } %>

<form method="GET" action="/products" class="mb-4 flex gap-2 items-end">
  <div>
    <label for="q" class="block text-xs text-gray-500 mb-1">Buscar</label>
    <input
      type="text" id="q" name="q" value="<%= q %>"
      placeholder="Nombre o SKU..."
      class="border border-gray-300 rounded px-3 py-2 text-sm w-64"
    />
  </div>
  <div>
    <label for="category" class="block text-xs text-gray-500 mb-1">Categoría</label>
    <select id="category" name="category" class="border border-gray-300 rounded px-3 py-2 text-sm">
      <option value="">Todas</option>
      <% categories.forEach(function(cat) { %>
        <option value="<%= cat.id %>" <%= String(categoryFilter) === String(cat.id) ? 'selected' : '' %>><%= cat.name %></option>
      <% }); %>
    </select>
  </div>
  <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">Buscar</button>
  <a href="/products" class="px-4 py-2 border border-gray-300 rounded text-sm hover:bg-gray-100">Limpiar</a>
</form>

<a href="/products/new" class="inline-block mb-4 px-4 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">
  + Nuevo Producto
</a>

<% if (products.length === 0) { %>
  <p class="text-gray-500">No hay productos registrados.</p>
<% } else { %>
  <table class="w-full border-collapse">
    <thead>
      <tr class="border-b border-gray-200 text-left text-sm text-gray-500">
        <th class="pb-2">Nombre</th>
        <th class="pb-2">SKU</th>
        <th class="pb-2">Categoría</th>
        <th class="pb-2">Stock</th>
        <th class="pb-2">Estado</th>
        <th class="pb-2">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(function(p) { %>
        <tr class="border-b border-gray-100">
          <td class="py-2"><%= p.name %></td>
          <td class="py-2 text-sm text-gray-600"><%= p.sku %></td>
          <td class="py-2 text-sm text-gray-600"><%= p.categoryName || '-' %></td>
          <td class="py-2"><%= p.stock %></td>
          <td class="py-2">
            <% if (p.active) { %>
              <span class="text-green-600 text-sm">Activo</span>
            <% } else { %>
              <span class="text-red-500 text-sm">Inactivo</span>
            <% } %>
          </td>
          <td class="py-2 flex gap-2">
            <a href="/products/<%= p.id %>/edit" class="text-blue-600 hover:underline text-sm">Editar</a>
            <form method="POST" action="/products/<%= p.id %>/toggle" class="inline">
              <button type="submit" class="text-gray-600 hover:underline text-sm">
                <%= p.active ? 'Desactivar' : 'Activar' %>
              </button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>
