<h2 class="text-2xl font-bold mb-6">Categorías</h2>

<% if (success) { %>
  <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
    <% if (success === 'created') { %>Categoría creada exitosamente.<% } %>
    <% if (success === 'updated') { %>Categoría actualizada exitosamente.<% } %>
    <% if (success === 'toggled') { %>Estado de categoría actualizado.<% } %>
  </div>
<% } %>

<a href="/categories/new" class="inline-block mb-4 px-4 py-2 bg-blue-600 text-white rounded text-sm hover:bg-blue-700">
  + Nueva Categoría
</a>

<% if (categories.length === 0) { %>
  <p class="text-gray-500">No hay categorías registradas.</p>
<% } else { %>
  <table class="w-full border-collapse">
    <thead>
      <tr class="border-b border-gray-200 text-left text-sm text-gray-500">
        <th class="pb-2">Nombre</th>
        <th class="pb-2">Estado</th>
        <th class="pb-2">Acciones</th>
      </tr>
    </thead>
    <tbody>
      <% categories.forEach(function(cat) { %>
        <tr class="border-b border-gray-100">
          <td class="py-2"><%= cat.name %></td>
          <td class="py-2">
            <% if (cat.active) { %>
              <span class="text-green-600 text-sm">Activo</span>
            <% } else { %>
              <span class="text-red-500 text-sm">Inactivo</span>
            <% } %>
          </td>
          <td class="py-2 flex gap-2">
            <a href="/categories/<%= cat.id %>/edit" class="text-blue-600 hover:underline text-sm">Editar</a>
            <form method="POST" action="/categories/<%= cat.id %>/toggle" class="inline">
              <button type="submit" class="text-gray-600 hover:underline text-sm">
                <%= cat.active ? 'Desactivar' : 'Activar' %>
              </button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
<% } %>
